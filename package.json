{
  "name": "uncoverit-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "fumadocs-mdx && bun --bun next build",
    "dev": "bun --bun next dev",
    "start": "bunx serve out",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@radix-ui/react-popover": "^1.1.17",
    "ajv": "^8.20.0",
    "class-variance-authority": "^0.7.1",
    "fumadocs-core": "16.10.4",
    "fumadocs-mdx": "15.0.12",
    "fumadocs-openapi": "^11.0.3",
    "fumadocs-ui": "16.10.4",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shiki": "^4.2.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "9",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  }
}
